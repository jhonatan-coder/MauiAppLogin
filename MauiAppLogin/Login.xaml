<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppLogin.Login"
             Title="Login">
    <VerticalStackLayout VerticalOptions="Center"
                         Padding="10"
                         Margin="10">
        <Label Text="Sistema de Login"
               HorizontalTextAlignment="Center"
               FontSize="Large"
               TextColor="Gray" />
        <Label Text="Usuario" VerticalTextAlignment="Center"
              Padding="10" />
        <Entry x:Name="txt_usuario" Placeholder="Digite seu login"/>
        <Label Text="Senha" VerticalTextAlignment="Center" 
               Padding="10"/>
        <Entry x:Name="txt_senha" IsPassword="True" Placeholder="Digite sua senha"/>

        <Button Text="Logar" HorizontalOptions="Center" 
                WidthRequest="100" 
                FontSize="Medium" 
                Margin="0,50,0,0"
                Clicked="Button_Clicked"/>
    </VerticalStackLayout>
</ContentPage>